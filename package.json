{
  "name": "visual-editor-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo root for visual-editor — visual gestures → deterministic source edits.",
  "workspaces": [
    "packages/*",
    "spikes/example-app"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:server": "npm run test -w @aaqiljamal/visual-editor-server",
    "test:mcp": "npm run test -w @aaqiljamal/visual-editor-mcp",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Design-Alchemist/visual-editor.git"
  }
}
